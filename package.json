{
  "name": "pokemon-battle-rooms",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:backend": "bun run --filter @pokemon-battle-rooms/backend dev",
    "dev:frontend": "bun run --filter @pokemon-battle-rooms/frontend dev",
    "import:pokemon": "bun run --filter @pokemon-battle-rooms/backend import:pokemon",
    "typecheck": "bun run --filter '*' typecheck",
    "build": "bun run --filter '*' build"
  }
}
