# Copia este archivo a .env y rellena tus valores locales.
# Nunca subas .env al repositorio.

# App
FRONTEND_URL=http://localhost:3000
PORT=3001
MONGO_URI=mongodb://localhost:27017/pokemon_battle_rooms
CORS_ORIGIN=*

# Google OAuth (obligatorio para crear/unir salas)
GOOGLE_CLIENT_ID=pega_aqui_tu_google_client_id
GOOGLE_CLIENT_SECRET=pega_aqui_tu_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
JWT_SECRET=cambia-esto-por-una-clave-larga-local

# Stripe (opcional — Pase Premium de prueba)
STRIPE_SECRET_KEY=sk_test_pega_aqui
STRIPE_WEBHOOK_SECRET=whsec_pega_aqui_cuando_uses_stripe_cli
STRIPE_PREMIUM_AMOUNT=499
STRIPE_PREMIUM_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:3000/premium/success
STRIPE_CANCEL_URL=http://localhost:3000/premium/cancel
